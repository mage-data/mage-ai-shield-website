---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ContactForm from '../components/forms/ContactForm.astro';
---

<BaseLayout
  title="Contact Us — AI Shield by Mage Data"
  description="Request a demo of AI Shield or get in touch with our team. Enterprise AI data compliance solutions."
>

  <!-- Hero -->
  <section class="pt-32 pb-16 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-accent-primary font-mono text-sm uppercase tracking-wider mb-4">Get in Touch</p>
      <h1 class="font-heading font-bold text-4xl md:text-5xl lg:text-6xl text-white leading-tight">
        Let's talk about your data
      </h1>
      <p class="text-text-secondary-dark text-xl md:text-2xl mt-6 max-w-2xl mx-auto">
        Request a demo, ask a question, or tell us about your compliance challenges. We respond within one business day.
      </p>
    </div>
  </section>

  <!-- Form + Contact Info -->
  <section class="py-16 md:py-24 px-6">
    <div class="max-w-7xl mx-auto">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">

        <!-- Contact Form -->
        <div class="bg-bg-secondary rounded-xl p-8 border border-white/5">
          <h2 class="font-heading font-bold text-2xl text-white mb-6">Send Us a Message</h2>
          <ContactForm />
        </div>

        <!-- Contact Info -->
        <div class="space-y-10">
          <div>
            <h2 class="font-heading font-bold text-2xl text-white mb-6">Contact Information</h2>
            <div class="space-y-6">

              <!-- Office Address -->
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-accent-primary/10 flex items-center justify-center">
                  <svg class="w-5 h-5 text-accent-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-heading font-semibold text-white mb-1">Office</h3>
                  <p class="text-text-secondary-dark leading-relaxed">
                    3 Columbus Circle, 15th Floor<br />
                    New York, NY 10019
                  </p>
                </div>
              </div>

              <!-- Email -->
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-accent-primary/10 flex items-center justify-center">
                  <svg class="w-5 h-5 text-accent-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-heading font-semibold text-white mb-1">Email</h3>
                  <a href="mailto:aishield@magedata.ai" class="text-accent-primary hover:text-accent-primary/80 transition-colors">
                    aishield@magedata.ai
                  </a>
                </div>
              </div>

              <!-- Sales -->
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-accent-primary/10 flex items-center justify-center">
                  <svg class="w-5 h-5 text-accent-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="font-heading font-semibold text-white mb-1">Sales Inquiries</h3>
                  <a href="mailto:sales@magedata.ai" class="text-accent-primary hover:text-accent-primary/80 transition-colors">
                    sales@magedata.ai
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Quick Actions -->
          <div class="bg-bg-secondary rounded-xl p-8 border border-white/5">
            <h3 class="font-heading font-bold text-lg text-white mb-4">Looking for something specific?</h3>
            <div class="space-y-3">
              <a href="/free-assessment" class="flex items-center gap-3 text-text-secondary-dark hover:text-accent-primary transition-colors group">
                <svg class="w-4 h-4 text-accent-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
                <span>Free AI Data Risk Assessment</span>
              </a>
              <a href="/platform" class="flex items-center gap-3 text-text-secondary-dark hover:text-accent-primary transition-colors group">
                <svg class="w-4 h-4 text-accent-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
                <span>Platform Overview</span>
              </a>
              <a href="/solutions/healthcare" class="flex items-center gap-3 text-text-secondary-dark hover:text-accent-primary transition-colors group">
                <svg class="w-4 h-4 text-accent-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
                <span>Healthcare Solutions</span>
              </a>
              <a href="/solutions/banking" class="flex items-center gap-3 text-text-secondary-dark hover:text-accent-primary transition-colors group">
                <svg class="w-4 h-4 text-accent-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
                <span>Banking Solutions</span>
              </a>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>

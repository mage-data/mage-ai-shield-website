---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionHeading from '../../../components/SectionHeading.astro';
import { getCollection } from 'astro:content';
import { url } from '../../../utils/links';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Blog — AI Shield" description="Insights on AI data compliance, training data protection, and the evolving enterprise AI governance landscape.">
  <section class="pt-32 pb-16 px-6">
    <div class="max-w-4xl mx-auto">
      <SectionHeading
        tag="Blog"
        title="Insights & Analysis"
        subtitle="Expert perspectives on AI data compliance, training data protection, and the evolving regulatory landscape."
      />

      <div class="mt-12 space-y-8">
        {posts.map(post => (
          <a href={url(`/resources/blog/${post.id}`)} class="block group">
            <article class="bg-bg-secondary rounded-xl p-8 border border-white/5 hover:border-accent-primary/20 transition-all duration-300">
              <div class="flex flex-wrap gap-2 mb-3">
                {post.data.tags.map(tag => (
                  <span class="px-2 py-0.5 text-xs font-mono bg-accent-primary/10 text-accent-primary rounded">
                    {tag}
                  </span>
                ))}
              </div>
              <h2 class="font-heading font-bold text-xl md:text-2xl text-white group-hover:text-accent-primary transition-colors">
                {post.data.title}
              </h2>
              <p class="text-text-secondary-dark mt-3 line-clamp-2">
                {post.data.description}
              </p>
              <div class="flex items-center gap-4 mt-4 text-text-secondary-dark/60 text-sm">
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <span>·</span>
                <span>{post.data.readTime}</span>
              </div>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="Page Not Found — AI Shield" description="The page you're looking for doesn't exist.">
  <section class="pt-32 pb-16 px-6 min-h-[60vh] flex items-center justify-center">
    <div class="text-center max-w-lg">
      <p class="font-mono text-accent-primary text-sm uppercase tracking-wider mb-4">404</p>
      <h1 class="font-heading font-bold text-4xl md:text-5xl text-white mb-4">Page not found</h1>
      <p class="text-text-secondary-dark text-lg mb-8">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <div class="flex gap-4 justify-center">
        <Button href="/" variant="primary">Go Home</Button>
        <Button href="/contact" variant="outlined">Contact Us</Button>
      </div>
    </div>
  </section>
</BaseLayout>

---
import { url } from '../utils/links';
---

<footer class="bg-bg-primary border-t border-white/5 pt-16 pb-8 px-6">
  <div class="max-w-7xl mx-auto">
    <!-- Link grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
      <!-- Platform -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-text-secondary-dark mb-4">Platform</h3>
        <ul class="space-y-3">
          <li><a href={url('/platform')} class="text-sm text-text-secondary-dark hover:text-accent-primary transition-colors">Platform Overview</a></li>
          <li><a href={url('/platform/training-data')} class="text-sm text-text-secondary-dark hover:text-accent-primary transition-colors">Training Data Protection</a></li>
          <li><a href={url('/platform/genai-firewall')} class="text-sm text-text-secondary-dark hover:text-accent-primary transition-colors">GenAI Firewall</a></li>
        </ul>
      </div>

      <!-- Solutions -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-text-secondary-dark mb-4">Solutions</h3>
        <ul class="space-y-3">
          <li><a href={url('/solutions/healthcare')} class="text-sm text-text-secondary-dark hover:text-accent-primary transition-colors">Healthcare</a></li>
          <li><a href={url('/solutions/banking')} class="text-sm text-text-secondary-dark hover:text-accent-primary transition-colors">Banking</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-text-secondary-dark mb-4">Resources</h3>
        <ul class="space-y-3">
          <li><a href={url('/resources/blog')} class="text-sm text-text-secondary-dark hover:text-accent-primary transition-colors">Blog</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-text-secondary-dark mb-4">Company</h3>
        <ul class="space-y-3">
          <li><a href={url('/company/about')} class="text-sm text-text-secondary-dark hover:text-accent-primary transition-colors">About</a></li>
          <li><a href={url('/contact')} class="text-sm text-text-secondary-dark hover:text-accent-primary transition-colors">Contact</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 mt-12 pt-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <!-- Logo + tagline -->
        <div class="flex flex-col items-center md:items-start gap-1">
          <span class="font-heading font-bold text-lg text-white">AI Shield</span>
          <span class="text-xs text-text-secondary-dark">A Mage Data product</span>
        </div>

        <!-- Copyright -->
        <p class="text-xs text-text-secondary-dark text-center">
          &copy; 2026 Mage Data AI Shield. All rights reserved.
        </p>

        <!-- Social icons -->
        <div class="flex items-center gap-4">
          <!-- LinkedIn -->
          <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-text-secondary-dark hover:text-accent-primary transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <!-- YouTube -->
          <a href="https://youtube.com" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="text-text-secondary-dark hover:text-accent-primary transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
          </a>
          <!-- X / Twitter -->
          <a href="https://x.com" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" class="text-text-secondary-dark hover:text-accent-primary transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Secondary bottom row -->
      <div class="flex flex-col md:flex-row items-center justify-between gap-4 mt-6">
        <div class="flex items-center gap-4 text-xs text-text-secondary-dark">
          <a href={url('/privacy')} class="hover:text-accent-primary transition-colors">Privacy Policy</a>
          <span class="opacity-40">|</span>
          <a href={url('/terms')} class="hover:text-accent-primary transition-colors">Terms</a>
          <span class="opacity-40">|</span>
          <span>ISO 27001 Certified</span>
        </div>
        <p class="text-xs text-text-secondary-dark">
          3 Columbus Circle, 15th Floor, New York, NY
        </p>
      </div>
    </div>
  </div>
</footer>

---
import SectionHeading from '../SectionHeading.astro';
import Button from '../Button.astro';
import { url } from '../../utils/links';

const steps = [
  { num: 1, title: 'Request', description: 'Data scientist requests a training dataset through the self-service portal' },
  { num: 2, title: 'Discover', description: 'AI Shield scans source systems and classifies sensitive data automatically' },
  { num: 3, title: 'Transform', description: 'Applies policy-driven de-identification while preserving ML utility' },
  { num: 4, title: 'Certify', description: 'Generates provenance certificate and compliance documentation' },
  { num: 5, title: 'Deliver', description: 'Pushes certified dataset to the requesting ML platform' },
];
---

<SectionHeading
  tag="HOW IT WORKS"
  title="Five steps to AI-ready data"
/>

<!-- Desktop: horizontal flow -->
<div class="hidden md:flex items-start justify-between mt-12 relative">
  {steps.map((step, i) => (
    <div class="flex-1 flex flex-col items-center text-center relative">
      <!-- Dashed connector line (not on last item) -->
      {i < steps.length - 1 && (
        <div class="absolute top-5 left-[calc(50%+24px)] right-[calc(-50%+24px)] border-t-2 border-dashed border-accent-primary/20 z-0" aria-hidden="true"></div>
      )}
      <!-- Number circle -->
      <div class="relative z-10 w-10 h-10 rounded-full bg-accent-primary/10 flex items-center justify-center mb-3">
        <span class="font-heading font-bold text-accent-primary text-sm">{step.num}</span>
      </div>
      <h3 class="font-heading font-semibold text-white text-sm mb-1">{step.title}</h3>
      <p class="text-text-secondary-dark text-xs leading-relaxed max-w-[160px]">{step.description}</p>
    </div>
  ))}
</div>

<!-- Mobile: vertical flow -->
<div class="md:hidden mt-12 space-y-6">
  {steps.map((step, i) => (
    <div class="flex gap-4 items-start">
      <div class="flex flex-col items-center">
        <div class="w-10 h-10 rounded-full bg-accent-primary/10 flex items-center justify-center shrink-0">
          <span class="font-heading font-bold text-accent-primary text-sm">{step.num}</span>
        </div>
        {i < steps.length - 1 && (
          <div class="w-0 h-6 border-l-2 border-dashed border-accent-primary/20 mt-2" aria-hidden="true"></div>
        )}
      </div>
      <div class="pt-2">
        <h3 class="font-heading font-semibold text-white text-sm mb-1">{step.title}</h3>
        <p class="text-text-secondary-dark text-xs leading-relaxed">{step.description}</p>
      </div>
    </div>
  ))}
</div>

<div class="text-center mt-10">
  <Button variant="outlined" href={url('/platform')}>See Platform Details</Button>
</div>

---
import SectionHeading from '../SectionHeading.astro';

const stages = [
  {
    number: '01',
    title: 'Data at Rest',
    description: 'Discover & classify sensitive data across 100+ enterprise sources',
    icon: 'database',
    color: 'text-danger',
    bgColor: 'bg-danger/10',
    borderColor: 'border-danger/30',
  },
  {
    number: '02',
    title: 'Data Extraction',
    description: 'Policy enforcement blocks unauthorized data extraction for AI',
    icon: 'extract',
    color: 'text-danger',
    bgColor: 'bg-danger/10',
    borderColor: 'border-danger/20',
  },
  {
    number: '03',
    title: 'Data Preparation',
    description: 'De-identify PII & PHI while preserving ML model utility',
    icon: 'shield',
    color: 'text-accent-secondary',
    bgColor: 'bg-accent-secondary/10',
    borderColor: 'border-accent-secondary/30',
  },
  {
    number: '04',
    title: 'Model Training',
    description: 'Access controls & audit trail track who trains on what data',
    icon: 'brain',
    color: 'text-accent-primary',
    bgColor: 'bg-accent-primary/10',
    borderColor: 'border-accent-primary/20',
  },
  {
    number: '05',
    title: 'Model Deployment',
    description: 'GenAI firewall protects data in prompts and responses',
    icon: 'rocket',
    color: 'text-accent-primary',
    bgColor: 'bg-accent-primary/10',
    borderColor: 'border-accent-primary/20',
  },
  {
    number: '06',
    title: 'Certified & Compliant',
    description: 'Provenance certificates prove compliance to regulators',
    icon: 'certificate',
    color: 'text-success',
    bgColor: 'bg-success/10',
    borderColor: 'border-success/30',
  },
];
---

<div>
  <SectionHeading
    tag="THE AI DATA JOURNEY"
    title="Protection at every step"
    subtitle="From raw enterprise data to certified AI-ready output — Mage Data safeguards your data throughout the entire AI lifecycle."
  />

  <!-- Gradient progress bar (desktop) -->
  <div class="hidden lg:block mt-12 mb-4 mx-auto max-w-5xl px-8">
    <div class="relative h-1.5 rounded-full overflow-hidden bg-white/5">
      <div class="journey-gradient-bar absolute inset-0 rounded-full"></div>
    </div>
    <div class="flex justify-between mt-2">
      <span class="text-danger text-[10px] font-mono uppercase tracking-wider">Unprotected</span>
      <span class="text-success text-[10px] font-mono uppercase tracking-wider">Fully Certified</span>
    </div>
  </div>

  <!-- Stage cards -->
  <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-4 journey-stages" id="journey-stages">
    {stages.map((stage, i) => (
      <div
        class:list={[
          'journey-stage relative rounded-xl p-5 border transition-all duration-500',
          'bg-bg-secondary hover:scale-[1.03]',
          stage.borderColor,
        ]}
        style={`--stage-index: ${i}`}
      >
        <!-- Stage number -->
        <div class="flex items-center justify-between mb-3">
          <span class:list={['font-mono text-xs font-bold tracking-wider', stage.color]}>
            {stage.number}
          </span>
          <!-- Shield badge -->
          <div class:list={['w-6 h-6 rounded-full flex items-center justify-center', stage.bgColor]}>
            <svg class:list={['w-3.5 h-3.5', stage.color]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
        </div>

        <!-- Icon -->
        <div class:list={['w-10 h-10 rounded-lg flex items-center justify-center mb-3', stage.bgColor]}>
          {stage.icon === 'database' && (
            <svg class:list={['w-5 h-5', stage.color]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
            </svg>
          )}
          {stage.icon === 'extract' && (
            <svg class:list={['w-5 h-5', stage.color]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
            </svg>
          )}
          {stage.icon === 'shield' && (
            <svg class:list={['w-5 h-5', stage.color]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m0-10.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.75c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.57-.598-3.75h-.152c-3.196 0-6.1-1.249-8.25-3.286zm0 13.036h.008v.008H12v-.008z" />
            </svg>
          )}
          {stage.icon === 'brain' && (
            <svg class:list={['w-5 h-5', stage.color]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
            </svg>
          )}
          {stage.icon === 'rocket' && (
            <svg class:list={['w-5 h-5', stage.color]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
            </svg>
          )}
          {stage.icon === 'certificate' && (
            <svg class:list={['w-5 h-5', stage.color]} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
            </svg>
          )}
        </div>

        <!-- Title -->
        <h3 class="font-heading font-semibold text-sm text-white mb-1.5">{stage.title}</h3>

        <!-- Description -->
        <p class="text-text-secondary-dark text-xs leading-relaxed">{stage.description}</p>

        <!-- Mobile connector (visible below lg) -->
        {i < stages.length - 1 && (
          <div class="lg:hidden flex justify-center py-2">
            <svg class="w-4 h-6 text-white/20" fill="none" viewBox="0 0 16 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 4v16m0 0l-3-3m3 3l3-3" />
            </svg>
          </div>
        )}
      </div>
    ))}
  </div>
</div>

<style>
  .journey-gradient-bar {
    background: linear-gradient(
      to right,
      #FF6B6B 0%,
      #FF6B6B 15%,
      #8B7BF7 40%,
      #00D4AA 70%,
      #34D399 100%
    );
  }

  /* Scroll-triggered staggered fade-in */
  .journey-stage {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease;
    transition-delay: calc(var(--stage-index) * 0.1s);
  }

  .journey-stages.is-visible .journey-stage {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .journey-stage {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const stages = document.getElementById('journey-stages');
  if (stages && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2 }
    );
    observer.observe(stages);
  } else if (stages) {
    stages.classList.add('is-visible');
  }
</script>

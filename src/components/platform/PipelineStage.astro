---
interface Props {
  number: string;
  title: string;
  description: string;
  features: string[];
  isOpen?: boolean;
}

const { number, title, description, features, isOpen = false } = Astro.props;
const panelId = `pipeline-panel-${number}`;
const headerId = `pipeline-header-${number}`;
---

<div class="border-b border-white/10 pipeline-accordion">
  <button
    id={headerId}
    class="w-full flex items-center gap-4 py-5 text-left group cursor-pointer"
    aria-expanded={isOpen ? 'true' : 'false'}
    aria-controls={panelId}
  >
    <span class="font-mono text-accent-primary text-sm shrink-0">{number}</span>
    <span class="font-heading font-semibold text-xl text-white flex-1">{title}</span>
    <svg
      class:list={[
        'w-5 h-5 text-text-secondary-dark shrink-0 transition-transform duration-200 accordion-chevron',
        isOpen && 'rotate-180',
      ]}
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="2"
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </button>
  <div
    id={panelId}
    role="region"
    aria-labelledby={headerId}
    class:list={['overflow-hidden transition-all duration-200', isOpen ? 'max-h-[500px] pb-6' : 'max-h-0']}
  >
    <div class="pl-10">
      <p class="text-text-secondary-dark mb-4">{description}</p>
      <ul class="space-y-2">
        {features.map((feature) => (
          <li class="flex items-start gap-2 text-sm text-text-secondary-dark">
            <span class="text-accent-primary mt-0.5 shrink-0">&#8226;</span>
            <span>{feature}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</div>

<style>
  @media (prefers-reduced-motion: reduce) {
    .accordion-chevron,
    [role="region"] {
      transition: none !important;
    }
  }
</style>

<script>
  function initAccordions() {
    document.querySelectorAll('.pipeline-accordion').forEach((accordion) => {
      const button = accordion.querySelector('button');
      const panel = accordion.querySelector('[role="region"]') as HTMLElement;
      const chevron = accordion.querySelector('.accordion-chevron');
      if (!button || !panel || !chevron) return;

      button.addEventListener('click', () => {
        const isExpanded = button.getAttribute('aria-expanded') === 'true';
        button.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');

        if (isExpanded) {
          panel.classList.remove('max-h-[500px]', 'pb-6');
          panel.classList.add('max-h-0');
          chevron.classList.remove('rotate-180');
        } else {
          panel.classList.remove('max-h-0');
          panel.classList.add('max-h-[500px]', 'pb-6');
          chevron.classList.add('rotate-180');
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initAccordions);
  initAccordions();
</script>

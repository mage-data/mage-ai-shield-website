---
const specs = [
  { label: 'Deployment', value: 'On-premises, private cloud, hybrid. No data leaves your environment.' },
  { label: 'Authentication', value: 'LDAP, Active Directory, SAML 2.0, OAuth 2.0' },
  { label: 'API', value: 'RESTful API, Python SDK, CLI tools' },
  { label: 'Audit', value: 'Immutable audit trail, SIEM integration (Splunk, Sentinel, QRadar)' },
  { label: 'Certifications', value: 'ISO 27001, SOC 2 Type II, HIPAA BAA' },
  { label: 'Performance', value: 'Process 1M+ records/hour, sub-second classification' },
];
---

<div class="bg-bg-secondary rounded-xl border border-white/5 p-6 md:p-8">
  <div class="grid gap-6 sm:grid-cols-2">
    {specs.map((spec) => (
      <div>
        <dt class="font-mono text-accent-primary text-xs uppercase tracking-wider mb-1">{spec.label}</dt>
        <dd class="text-text-secondary-dark text-sm">{spec.value}</dd>
      </div>
    ))}
  </div>
</div>

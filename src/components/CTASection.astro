---
import Button from './Button.astro';

interface Props {
  heading: string;
  subheading?: string;
  primaryCta: { text: string; href: string };
  secondaryCta?: { text: string; href: string };
}

const { heading, subheading, primaryCta, secondaryCta } = Astro.props;
---

<section class="bg-bg-secondary relative overflow-hidden">
  <!-- Radial gradient glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-accent-primary/5 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

  <div class="max-w-4xl mx-auto text-center py-16 md:py-24 px-6 relative z-10">
    <h2 class="font-heading font-bold text-3xl md:text-4xl text-white">
      {heading}
    </h2>
    {subheading && (
      <p class="text-text-secondary-dark text-lg mt-4 max-w-2xl mx-auto">
        {subheading}
      </p>
    )}
    <div class="flex gap-4 justify-center mt-8">
      <Button href={primaryCta.href}>{primaryCta.text}</Button>
      {secondaryCta && (
        <Button variant="outlined" href={secondaryCta.href}>{secondaryCta.text}</Button>
      )}
    </div>
  </div>
</section>

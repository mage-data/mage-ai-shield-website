---
interface Props {
  items: string[];
  heading?: string;
}

const { items, heading } = Astro.props;
---

<div class="py-8 border-y border-white/5">
  {heading && (
    <p class="text-text-secondary-dark text-xs uppercase tracking-wider text-center mb-6">
      {heading}
    </p>
  )}
  <div class="flex flex-wrap justify-center items-center gap-8 md:gap-12">
    {items.map((item) => (
      <span class="text-text-secondary-dark/60 text-sm font-medium">{item}</span>
    ))}
  </div>
</div>
